Proceso sin_titulo
	Definir  A,B,C como entero;
	Escribir "Ingrese el lado A";
	leer A;
	Escribir  "Ingrese el lado B";
	leer B;
	Escribir  "Ingrese el lado C";
	Leer C;
	si (A+B > C) Y (B+C>A) Y (C+A>B) Entonces
		Escribir "Con esas medidas es posible realizar un triangulo";
	sino
		Escribir "con esas medidas no es posible realizar un triangulo";
	FinSi
FinProceso
